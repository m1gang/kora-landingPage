---
import "../styles/global.css";

const title = "KORA | Bienes Raíces de Lujo — Propiedades Exclusivas";
const description =
  "Bienvenido a KORA, tu asesor inmobiliario de confianza. Descubre propiedades exclusivas de lujo en las ubicaciones más prestigiosas.";
const image = "/isotipo-kora.svg";
const url = "https://korarealty.com";

const schema = {
  "@context": "https://schema.org",
  "@type": "RealEstateAgent",
  name: "KORA Realty",
  description:
    "Agencia inmobiliaria especializada en propiedades de lujo y bienes raíces exclusivos.",
  url: "https://korarealty.com",
  logo: "https://korarealty.com/isotipo-kora.svg",
  image: "https://korarealty.com/isotipo-kora.svg",
  telephone: "+34 910 000 000",
  email: "info@korarealty.com",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Calle de Serrano, 42",
    addressLocality: "Madrid",
    addressCountry: "ES",
  },
  areaServed: ["ES", "PT", "FR"],
  priceRange: "$$$$",
  numberOfEmployees: {
    "@type": "QuantitativeValue",
    minValue: 15,
    maxValue: 50,
  },
  foundingDate: "2012",
  founder: { "@type": "Person", name: "KORA Group" },
  sameAs: [
    "https://instagram.com/korarealty",
    "https://linkedin.com/company/korarealty",
  ],
};
---

<!doctype html>
<html class="light" lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/isotipo-kora.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&display=swap" media="print" onload="this.onload=null;this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&display=swap" /></noscript>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" media="print" onload="this.media=null;this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" /></noscript>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={url} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={url} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="KORA Realty" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(schema, null, 2)}
    />

    <slot name="head" />
  </head>
  <body
    class="bg-background text-on-surface font-body-md overflow-x-hidden selection:bg-primary-fixed"
  >
    <slot />
  </body>
</html>
