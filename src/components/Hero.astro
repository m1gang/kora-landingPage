---
import { Image } from "astro:assets";
import hero1 from "../assets/images/hero-1.webp";
import hero2 from "../assets/images/hero-2.webp";
import hero3 from "../assets/images/hero-8.webp";
import hero4 from "../assets/images/hero-9.webp";
import heroSection1 from "../assets/images/hero-section-1.webp";
---

<section class="relative overflow-hidden p-3 h-screen" id="inicio">
  <svg class="absolute w-0 h-0" aria-hidden="true" focusable="false">
    <defs>
      <clipPath id="heroNotchClip" clipPathUnits="objectBoundingBox">
        <path
          d="M 0.016000 0.000000 L 0.984000 0.000000 A 0.016000 0.027586 0 0 1 1.000000 0.027586 L 1.000000 0.972414 A 0.016000 0.027586 0 0 1 0.984000 1.000000 L 0.400000 1.000000 A 0.021333 0.036782 0 0 1 0.384913 0.989230 L 0.354753 0.937207 A 0.021333 0.036782 0 0 0 0.339667 0.926437 L 0.016000 0.926437 A 0.016000 0.027586 0 0 1 0.000000 0.898851 L 0.000000 0.027586 A 0.016000 0.027586 0 0 1 0.016000 0.000000 Z"
        ></path>
      </clipPath>
    </defs>
  </svg>
  <div class="relative h-full w-full overflow-hidden group hero-notch">
    <Image
      src={hero1}
      alt=""
      loading="eager"
      fetchpriority="high"
      width={1920}
      height={1080}
      quality={80}
      class="hero-slide absolute inset-0 w-full h-full object-cover transition-all duration-1000 ease-in-out group-hover:scale-105 rounded-2xl opacity-100"
    />
    <Image
      src={hero2}
      alt=""
      loading="lazy"
      decoding="async"
      width={1920}
      height={1080}
      quality={80}
      class="hero-slide absolute inset-0 w-full h-full object-cover transition-all duration-1000 ease-in-out group-hover:scale-105 rounded-2xl opacity-0"
    />
    <Image
      src={hero3}
      alt=""
      loading="lazy"
      decoding="async"
      width={1920}
      height={1080}
      quality={80}
      class="hero-slide absolute inset-0 w-full h-full object-cover transition-all duration-1000 ease-in-out group-hover:scale-105 rounded-2xl opacity-0"
    />
    <Image
      src={hero4}
      alt=""
      loading="lazy"
      decoding="async"
      width={1920}
      height={1080}
      quality={80}
      class="hero-slide absolute inset-0 w-full h-full object-cover transition-all duration-1000 ease-in-out group-hover:scale-105 rounded-2xl opacity-0"
    />
    <div
      class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"
    >
    </div>
    <div
      class="absolute inset-0 flex flex-col justify-end p-8 md:p-20 text-white pb-32 md:pb-40"
    >
      <h1
        class="font-display-lg text-[40px] md:text-[60px] lg:text-[75px] font-medium leading-none mb-6 text-white mix-blend-difference reveal fade-in-up"
      >
        Elevando el Estilo de Vida<br />
        <span class="italic font-black">en el Corazón de Perú</span>
      </h1>
      <p
        class="font-body-lg text-body-lg max-w-xl opacity-90 reveal fade-in-up delay-100 mix-blend-difference"
      >
        Bienvenidos a un mundo donde el lujo arquitectónico se encuentra con la
        calidez del hogar. Descubre nuestra colección curada de propiedades en
        las zonas más exclusivas del país.
      </p>
    </div>
    <div
      class="absolute bottom-20 right-10 hidden lg:block w-72 glass-effect rounded-3xl p-4 border border-white/10 backdrop-blur-md bg-white/10 reveal fade-in-up animate-float-gentle"
    >
      <div class="h-40 rounded-2xl overflow-hidden mb-4">
        <Image
          class="w-full h-full object-cover"
          src={heroSection1}
          alt="Refugio exclusivo Kora"
          loading="lazy"
          width={400}
          height={250}
          quality={75}
        />
      </div>
      <p class="font-label-lg text-white mb-4">
        Encuentra el refugio que se adapta a tu visión
      </p>
      <a
        href="#propiedades-destacadas"
        class="block w-full py-2 text-center bg-white/20 text-white rounded-xl font-label-sm border border-white/30 hover:bg-white/40 hover:scale-[1.02] active:scale-95 transition-all duration-300 cursor-pointer"
        >Explorar Colección</a
      >
    </div>
  </div>
  <div
    class="absolute bottom-5 sm:bottom-6 md:bottom-7 left-1/2 -translate-x-1/2 md:left-6 md:translate-x-0 flex gap-2 sm:gap-3 md:gap-3 lg:gap-3 px-2 sm:px-4 w-[85%] sm:w-[70%] md:w-[35%] lg:w-[35%] max-w-[650px] transition-all duration-300 z-10 delay-200"
  >
    <button
      class="hero-dot group relative flex-1 h-2 sm:h-2.5 md:h-3 lg:h-4 overflow-hidden skew-x-12 bg-white/20 border border-[#1E2820] rounded-sm cursor-pointer transition-all duration-300 active"
      data-slide="0"
      aria-label="Slide 1"
    >
      <div
        class="hero-dot-progress absolute left-0 top-0 h-full w-0 bg-[#181e1b]"
      >
      </div>
    </button>
    <button
      class="hero-dot group relative flex-1 h-2 sm:h-2.5 md:h-3 lg:h-4 overflow-hidden skew-x-12 bg-white/20 border border-[#260001] rounded-sm cursor-pointer transition-all duration-300"
      data-slide="1"
      aria-label="Slide 2"
    >
      <div
        class="hero-dot-progress absolute left-0 top-0 h-full w-0 bg-[#161313]"
      >
      </div>
    </button>
    <button
      class="hero-dot group relative flex-1 h-2 sm:h-2.5 md:h-3 lg:h-4 overflow-hidden skew-x-12 bg-white/20 border border-[#3A4642] rounded-sm cursor-pointer transition-all duration-300"
      data-slide="2"
      aria-label="Slide 3"
    >
      <div
        class="hero-dot-progress absolute left-0 top-0 h-full w-0 bg-[#0c1210]"
      >
      </div>
    </button>
    <button
      class="hero-dot group relative flex-1 h-2 sm:h-2.5 md:h-3 lg:h-4 overflow-hidden skew-x-12 bg-white/20 border border-[#2F3D48] rounded-sm cursor-pointer transition-all duration-300"
      data-slide="3"
      aria-label="Slide 4"
    >
      <div
        class="hero-dot-progress absolute left-0 top-0 h-full w-0 bg-[#12181c]"
      >
      </div>
    </button>
  </div>

  <script>
    function initHeroCarousel() {
      const slides = document.querySelectorAll(".hero-slide");
      const dots = document.querySelectorAll(".hero-dot");
      let currentIndex = 0;
      let slideInterval: any;
      const duration = 5000;

      if (slides.length === 0 || dots.length === 0) return;

      function showSlide(index: number) {
        slides.forEach((slide, i) => {
          if (i === index) {
            slide.classList.remove("opacity-0");
            slide.classList.add("opacity-100");
          } else {
            slide.classList.remove("opacity-100");
            slide.classList.add("opacity-0");
          }
        });

        dots.forEach((dot, i) => {
          const progress = dot.querySelector(
            ".hero-dot-progress",
          ) as HTMLElement;
          if (!progress) return;

          if (i === index) {
            dot.classList.add("active");
            progress.style.transition = "none";
            progress.style.width = "0%";

            // Force reflow
            progress.offsetHeight;

            progress.style.transition = `width ${duration}ms linear`;
            progress.style.width = "100%";
          } else {
            dot.classList.remove("active");
            progress.style.transition = "none";
            progress.style.width = "0%";
          }
        });

        currentIndex = index;
      }

      function nextSlide() {
        let nextIndex = (currentIndex + 1) % slides.length;
        showSlide(nextIndex);
      }

      function startAutoSlide() {
        showSlide(currentIndex);
        slideInterval = setInterval(nextSlide, duration);
      }

      function resetInterval() {
        clearInterval(slideInterval);
        slideInterval = setInterval(nextSlide, duration);
      }

      dots.forEach((dot, index) => {
        dot.addEventListener("click", () => {
          showSlide(index);
          resetInterval();
        });
      });

      startAutoSlide();
    }

    document.addEventListener("DOMContentLoaded", initHeroCarousel);
    document.addEventListener("astro:page-load", initHeroCarousel);
  </script>

  <style>
    /* Clip-path solo en pantallas medianas y grandes */
    @media (min-width: 768px) {
      .hero-notch {
        clip-path: url(#heroNotchClip);
      }
    }

    @keyframes floatGentle {
      0%,
      100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-10px);
      }
    }

    .animate-float-gentle {
      animation: floatGentle 5s ease-in-out infinite;
    }
  </style>
</section>
