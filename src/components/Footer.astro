---
import { Image } from "astro:assets";
import logoKora from "../assets/icons/ISOTIPO-LOGOTIPO.svg";
---

<footer class="bg-tertiary text-on-tertiary w-full rounded-t-[48px]">
  <div
    class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-20 flex flex-col gap-20"
  >
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="space-y-6">
        <p
          class="font-label-lg uppercase tracking-widest border-b border-white/10 pb-4"
        >
          Enlaces Rápidos
        </p>
        <ul class="space-y-3 font-body-md text-on-tertiary/60">
          <li>
            <a class="hover:text-on-tertiary transition-colors" href="#"
              >Propiedades</a
            >
          </li>
          <li>
            <a class="hover:text-on-tertiary transition-colors" href="#"
              >Servicios</a
            >
          </li>
          <li>
            <a class="hover:text-on-tertiary transition-colors" href="#"
              >Sobre Nosotros</a
            >
          </li>
          <li>
            <a class="hover:text-on-tertiary transition-colors" href="#">Blog</a
            >
          </li>
        </ul>
      </div>
      <div class="space-y-6">
        <p
          class="font-label-lg uppercase tracking-widest border-b border-white/10 pb-4"
        >
          Recursos
        </p>
        <ul class="space-y-3 font-body-md text-on-tertiary/60">
          <li>
            <a class="hover:text-on-tertiary transition-colors" href="#"
              >Centro de Ayuda</a
            >
          </li>
          <li>
            <a class="hover:text-on-tertiary transition-colors" href="#"
              >Documentación</a
            >
          </li>
          <li>
            <a class="hover:text-on-tertiary transition-colors" href="#"
              >API Reference</a
            >
          </li>
        </ul>
      </div>
      <div class="space-y-6">
        <p
          class="font-label-lg uppercase tracking-widest border-b border-white/10 pb-4"
        >
          Contacto
        </p>
        <ul class="space-y-3 font-body-md text-on-tertiary/60">
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-sm">location_on</span> Calle
            de Serrano, Madrid
          </li>
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-sm">call</span> +34 910 000
            000
          </li>
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-sm">mail</span> info@korarealty.com
          </li>
        </ul>
      </div>
      <div class="space-y-6">
        <p
          class="font-label-lg uppercase tracking-widest border-b border-white/10 pb-4"
        >
          Newsletter
        </p>
        <div class="flex bg-white/5 rounded-full p-1 border border-white/10">
          <input
            class="bg-transparent border-none focus:ring-0 flex-1 px-6 text-on-tertiary text-sm"
            placeholder="Tu email"
            type="email"
          />
          <button
            class="w-12 h-12 bg-white text-black rounded-full flex items-center justify-center hover:scale-105 transition-transform active:scale-95"
          >
            <span class="material-symbols-outlined">arrow_forward</span>
          </button>
        </div>
      </div>
    </div>
    <div class="flex justify-center">
      <Image src={logoKora} alt="KORA Logo" class="brightness-0 invert" />
    </div>
    <div
      class="flex flex-col md:flex-row justify-between items-center border-t border-white/5 pt-10 font-body-md text-on-tertiary/40"
    >
      <p>&copy; 2026 KORA. Exclusivity through Simplicity.</p>
      <div class="flex gap-8 mt-4 md:mt-0">
        <a class="hover:text-on-tertiary transition-colors" href="#"
          >Privacidad</a
        >
        <a class="hover:text-on-tertiary transition-colors" href="#">Términos</a
        >
        <a class="hover:text-on-tertiary transition-colors" href="#">Cookies</a>
      </div>
    </div>
  </div>
</footer>
