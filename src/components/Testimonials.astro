---
import { Image } from "astro:assets";
import person1 from "../assets/images/testimonial-1-person.webp";
import person2 from "../assets/images/testimonial-2-person.webp";
import person3 from "../assets/images/testimonial-3-person.webp";
import person4 from "../assets/images/testimonial-4-person.webp";
import property1 from "../assets/images/testimonial-1.webp";
import property2 from "../assets/images/testimonial-2.webp";
import property3 from "../assets/images/testimonial-3.webp";
import property4 from "../assets/images/testimonial-4.webp";
---

<section class="py-stack-lg bg-transparent overflow-hidden">
  <div
    class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop relative"
  >
    <div class="carousel-container overflow-hidden">
      <div
        class="carousel-track flex transition-transform duration-700 ease-in-out"
        id="testimonialTrack"
      >
        <!-- Testimonial 1 -->
        <div
          class="carousel-item min-w-full flex flex-col md:flex-row gap-16 items-center px-4 md:px-20"
        >
          <div class="flex-1 space-y-8 reveal fade-in">
            <span
              class="material-symbols-outlined text-primary text-6xl"
              style='font-variation-settings: "FILL" 1;'>format_quote</span
            >
            <h2 class="font-display-lg text-headline-lg italic">
              &ldquo;KORA no solo nos ayudó a encontrar un departamento, sino
              una pieza de arte arquitectónico frente al mar. Su conocimiento
              del mercado limeño y su atención al detalle son
              inigualables.&rdquo;
            </h2>
            <div class="flex items-center gap-4">
              <div
                class="w-16 h-16 rounded-lg overflow-hidden shadow-lg border border-white/20"
              >
                <Image
                  alt="Mariana de la Fuente"
                  class="w-full h-full object-cover"
                  src={person1}
                  width={64}
                  height={64}
                  quality={75}
                  loading="lazy"
                />
              </div>
              <div>
                <p class="font-label-lg text-black">Mariana de la Fuente</p>
                <p
                  class="text-label-sm text-secondary uppercase tracking-widest"
                >
                  Inversionista y Curadora de Arte
                </p>
              </div>
            </div>
          </div>
          <div class="flex-1 hidden md:block reveal slide-in-right">
            <Image
              class="rounded-[32px] w-full aspect-square object-cover shadow-2xl"
              src={property1}
              alt="Penthouse frente al mar"
              loading="lazy"
              width={600}
              height={600}
              quality={80}
            />
          </div>
        </div>

        <!-- Testimonial 2 -->
        <div
          class="carousel-item min-w-full flex flex-col md:flex-row gap-16 items-center px-4 md:px-20"
        >
          <div class="flex-1 space-y-8 reveal fade-in">
            <span
              class="material-symbols-outlined text-primary text-6xl"
              style='font-variation-settings: "FILL" 1;'>format_quote</span
            >
            <h2 class="font-display-lg text-headline-lg italic">
              &ldquo;La discreción y el profesionalismo de KORA superaron todas
              mis expectativas. Encontraron la pieza perfecta para mi portfolio
              de inversión en San Isidro.&rdquo;
            </h2>
            <div class="flex items-center gap-4">
              <div
                class="w-16 h-16 rounded-lg overflow-hidden shadow-lg border border-white/20"
              >
                <Image
                  alt="David Chen"
                  class="w-full h-full object-cover"
                  src={person2}
                  width={64}
                  height={64}
                  quality={75}
                  loading="lazy"
                />
              </div>
              <div>
                <p class="font-label-lg text-black">David Chen</p>
                <p
                  class="text-label-sm text-secondary uppercase tracking-widest"
                >
                  CEO de TechVision Perú
                </p>
              </div>
            </div>
          </div>
          <div class="flex-1 hidden md:block reveal slide-in-right">
            <Image
              class="rounded-[32px] w-full aspect-[16/9] object-cover shadow-2xl"
              src={property2}
              alt="Residencia moderna de lujo"
              loading="lazy"
              width={600}
              height={338}
              quality={80}
            />
          </div>
        </div>

        <!-- Testimonial 3 -->
        <div
          class="carousel-item min-w-full flex flex-col md:flex-row gap-16 items-center px-4 md:px-20"
        >
          <div class="flex-1 space-y-8 reveal fade-in">
            <span
              class="material-symbols-outlined text-primary text-6xl"
              style='font-variation-settings: "FILL" 1;'>format_quote</span
            >
            <h2 class="font-display-lg text-headline-lg italic">
              &ldquo;Como arquitecta, valoro la pureza de las líneas. KORA
              entiende el lenguaje del diseño contemporáneo como nadie en el
              mercado local.&rdquo;
            </h2>
            <div class="flex items-center gap-4">
              <div
                class="w-16 h-16 rounded-lg overflow-hidden shadow-lg border border-white/20"
              >
                <Image
                  alt="Sofía Rossi"
                  class="w-full h-full object-cover"
                  src={person3}
                  width={64}
                  height={64}
                  quality={75}
                  loading="lazy"
                />
              </div>
              <div>
                <p class="font-label-lg text-black">Sofía Rossi</p>
                <p
                  class="text-label-sm text-secondary uppercase tracking-widest"
                >
                  Arquitecta Principal
                </p>
              </div>
            </div>
          </div>
          <div class="flex-1 hidden md:block reveal slide-in-right">
            <Image
              class="rounded-[32px] w-full aspect-square object-cover shadow-2xl"
              src={property3}
              alt="Detalle arquitectónico de villa"
              loading="lazy"
              width={600}
              height={600}
              quality={80}
            />
          </div>
        </div>

        <!-- Testimonial 4 -->
        <div
          class="carousel-item min-w-full flex flex-col md:flex-row gap-16 items-center px-4 md:px-20"
        >
          <div class="flex-1 space-y-8 reveal fade-in">
            <span
              class="material-symbols-outlined text-primary text-6xl"
              style='font-variation-settings: "FILL" 1;'>format_quote</span
            >
            <h2 class="font-display-lg text-headline-lg italic">
              &ldquo;Buscábamos un retiro sostenible sin sacrificar la elegancia
              en el Valle Sagrado. El equipo de KORA nos guió hacia la elección
              perfecta.&rdquo;
            </h2>
            <div class="flex items-center gap-4">
              <div
                class="w-16 h-16 rounded-lg overflow-hidden shadow-lg border border-white/20"
              >
                <Image
                  alt="Marc Julià"
                  class="w-full h-full object-cover"
                  src={person4}
                  width={64}
                  height={64}
                  quality={75}
                  loading="lazy"
                />
              </div>
              <div>
                <p class="font-label-lg text-black">Marc Julià</p>
                <p
                  class="text-label-sm text-secondary uppercase tracking-widest"
                >
                  Fundador de EcoSmart Living
                </p>
              </div>
            </div>
          </div>
          <div class="flex-1 hidden md:block reveal slide-in-right">
            <Image
              class="rounded-[32px] w-full aspect-[4/3] object-cover shadow-2xl"
              src={property4}
              alt="Villa ecológica en Cusco"
              loading="lazy"
              width={600}
              height={450}
              quality={80}
            />
          </div>
        </div>
      </div>
    </div>
    <div class="absolute lg:inset-y-0 left-10 flex items-center">
      <button
        class="w-12 h-12 rounded-lg bg-white/80 backdrop-blur shadow-lg border border-outline/10 flex items-center justify-center hover:bg-white transition-colors ml-4 md:-ml-6 group"
        id="prevBtn"
        aria-label="Testimonio Anterior"
      >
        <span
          class="material-symbols-outlined text-primary group-hover:-translate-x-1 transition-transform"
          >chevron_left</span
        >
      </button>
    </div>
    <div class="absolute lg:inset-y-0 right-10 flex items-center">
      <button
        class="w-12 h-12 rounded-lg bg-white/80 backdrop-blur shadow-lg border border-outline/10 flex items-center justify-center hover:bg-white transition-colors mr-4 md:-mr-6 group"
        id="nextBtn"
        aria-label="Testimonio Siguiente"
      >
        <span
          class="material-symbols-outlined text-primary group-hover:translate-x-1 transition-transform"
          >chevron_right</span
        >
      </button>
    </div>
  </div>
</section>