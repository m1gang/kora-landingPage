---
import Image from "astro/components/Image.astro";
---

<section
  class="py-stack-lg max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop"
  id="nosotros"
>
  <div class="flex flex-col lg:flex-row gap-16 items-center">
    <div class="flex-1">
      <h2 class="font-display-lg text-display-lg mb-8 reveal slide-in-left">
        Tus asesores de <br />
        <span class="italic">Confianza</span>
      </h2>
      <p
        class="text-secondary max-w-md mb-12 font-body-lg reveal fade-in delay-100"
      >
        Descubre el epítome de la vida de lujo en esta oferta que ofrece amplias
        vistas panorámicas al océano desde cada habitación.
      </p>
      <div class="grid grid-cols-2 gap-4">
        <div
          class="p-8 bg-surface-container rounded-[32px] text-center border border-outline/5 hover:bg-white transition-all duration-300 reveal fade-in-up delay-100"
        >
          <h3 class="font-headline-lg text-headline-lg mb-2">18k+</h3>
          <p class="text-label-sm text-secondary uppercase tracking-widest">
            Clientes Satisfechos
          </p>
        </div>
        <div
          class="p-8 bg-tertiary text-on-tertiary rounded-[32px] text-center active:scale-95 transition-transform duration-300 reveal fade-in-up delay-200"
        >
          <h3 class="font-headline-lg text-headline-lg mb-2">17k+</h3>
          <p
            class="text-label-sm text-on-tertiary/70 uppercase tracking-widest"
          >
            Socios
          </p>
        </div>
        <div
          class="p-8 bg-surface-container rounded-[32px] text-center border border-outline/5 hover:bg-white transition-all duration-300 reveal fade-in-up delay-300"
        >
          <h3 class="font-headline-lg text-headline-lg mb-2">13+</h3>
          <p class="text-label-sm text-secondary uppercase tracking-widest">
            Años de Experiencia
          </p>
        </div>
        <div
          class="p-8 bg-surface-container rounded-[32px] text-center border border-outline/5 hover:bg-white transition-all duration-300 reveal fade-in-up delay-400"
        >
          <h3 class="font-headline-lg text-headline-lg mb-2">14k+</h3>
          <p class="text-label-sm text-secondary uppercase tracking-widest">
            Propiedades Disponibles
          </p>
        </div>
      </div>
    </div>
    <div class="flex-1 w-full reveal fade-in-up delay-200">
      <div
        class="aspect-[4/3] rounded-[48px] overflow-hidden shadow-2xl relative"
      >
        <img
          class="w-full h-full object-cover"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuCFbQ_BtT2kmpIszcA2mKrZ5554P9AmNRM6NyGVkDN5h4osdo9HPfSR7aEvKIpN6ss5g5Z0jp82EdkNPSc_uI-aWmE3uHbvdO22BbFBzBCgzX6-oNUi0oCBqkmzaf81mfOzt0fLzCU5YDkmpkB0kBsRo8sQUtCgBuhPekAYFxIpBb_CeBSAIzOR7w0HBnEW9ibVqmqnPocySc5h0oseElXeugpJcIqoHlkDxvqXF2br4vL0gA-SIKezwAkeN0l2GWH9jj7nFkFCMLXQ"
          alt="Vista exterior de mansión moderna"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
