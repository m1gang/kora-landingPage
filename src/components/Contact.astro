      <form class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label class="font-label-sm uppercase tracking-widest text-secondary">Nombre</label>
            <input class="w-full bg-surface-container border-none rounded-lg p-4 focus:ring-2 focus:ring-primary transition-all" placeholder="Tu nombre aquí" type="text"/>
          </div>
          <div class="space-y-2">
