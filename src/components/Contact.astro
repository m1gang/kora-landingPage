---
import { Image } from "astro:assets";
import officeThumb from "../assets/images/contact.webp";
---

<section
  class="py-stack-lg max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop"
  id="contacto"
>
  <div class="flex flex-col lg:flex-row gap-20">
    <div class="flex-1 reveal fade-in-up delay-100">
      <h2 class="font-display-lg text-display-lg mb-4">
        Pongámonos en <br /><span class="italic">contacto</span>
      </h2>
      <p class="text-secondary mb-12 font-body-lg">
        ¿Listo para encontrar la casa de tus sueños, realizar una inversión
        inteligente o necesitas asesoramiento inmobiliario?
      </p>
      <form class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label
              class="font-label-sm uppercase tracking-widest text-secondary"
              >Nombre</label
            >
            <input
              class="w-full bg-surface-container border-none rounded-lg p-4 focus:ring-2 focus:ring-primary transition-all text-black font-medium"
              placeholder="Tu nombre aquí"
              type="text"
              required
            />
          </div>
          <div class="space-y-2">
            <label
              class="font-label-sm uppercase tracking-widest text-secondary"
              >Apellido</label
            >
            <input
              class="w-full bg-surface-container border-none rounded-lg p-4 focus:ring-2 focus:ring-primary transition-all text-black font-medium"
              placeholder="Tu apellido aquí"
              type="text"
              required
            />
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label
              class="font-label-sm uppercase tracking-widest text-secondary"
              >Email</label
            >
            <input
              class="w-full bg-surface-container border-none rounded-lg p-4 focus:ring-2 focus:ring-primary transition-all text-black font-medium"
              placeholder="contacto@kora.pe"
              type="email"
              required
            />
          </div>
          <div class="space-y-2">
            <label
              class="font-label-sm uppercase tracking-widest text-secondary"
              >Teléfono</label
            >
            <input
              class="w-full bg-surface-container border-none rounded-lg p-4 focus:ring-2 focus:ring-primary transition-all text-black font-medium"
              placeholder="+51 987 654 321"
              type="tel"
            />
          </div>
        </div>
        <div class="space-y-2">
          <label class="font-label-sm uppercase tracking-widest text-secondary"
            >Mensaje</label
          >
          <textarea
            class="w-full bg-surface-container border-none rounded-lg p-4 focus:ring-2 focus:ring-primary transition-all text-black font-medium"
            placeholder="¿Cómo podemos ayudarte?"
            rows="4"
            required></textarea>
        </div>
        <button
          class="w-full bg-primary text-on-primary py-5 rounded-lg font-label-lg uppercase tracking-widest hover:bg-opacity-90 active:scale-[0.98] transition-all duration-300"
          >Enviar Mensaje</button
        >
      </form>
    </div>
    <div
      class="flex-1 min-h-[500px] rounded-[48px] overflow-hidden relative bg-surface-container reveal fade-in-up delay-200"
    >
      <div
        class="absolute inset-0 w-full h-full bg-gradient-to-br from-[#1e1e2a] via-[#2a2a3a] to-[#1a1a2e]"
      >
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3902.2876083230103!2d-77.04967159217718!3d-12.02371006263071!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9105cf72542fd2b3%3A0xb910afcf22c139c5!2sCondisa%20Romero!5e0!3m2!1ses-419!2spe!4v1784692992236!5m2!1ses-419!2spe"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="strict-origin-when-cross-origin"></iframe>
      </div>
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 glass-effect p-4 rounded-3xl border border-white/20 shadow-2xl animate-bounce-slow backdrop-blur-md bg-white/20"
      >
        <div class="h-32 rounded-lg overflow-hidden mb-3">
          <Image
            class="w-full h-full object-cover"
            src={officeThumb}
            alt="Edificio Capital, San Isidro, Lima"
            loading="lazy"
            width={256}
            height={160}
            quality={75}
          />
        </div>
        <p class="font-label-lg text-primary text-xs mb-1 font-bold">
          Edificio Capital
        </p>
        <p class="text-[10px] text-secondary mb-3 font-semibold">
          Av. Javier Prado Este 1520, San Isidro, Lima
        </p>
        <button
          class="w-full py-2 bg-black text-white rounded-lg text-[10px] uppercase font-bold transition-colors duration-300 hover:bg-opacity-80"
          >Cómo llegar</button
        >
      </div>
    </div>
  </div>
</section>
