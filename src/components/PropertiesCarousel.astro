---
import { Image } from "astro:assets";
import prop1 from "../assets/images/properties-1.webp";
import prop2 from "../assets/images/properties-2.webp";
import prop3 from "../assets/images/properties-3.webp";
import prop4 from "../assets/images/properties-4.webp";
---

<section
  class="py-stack-lg bg-transparent overflow-hidden"
  id="propiedades-destacadas"
>
  <div
    class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-12"
  >
    <div
      class="flex flex-col md:flex-row justify-between items-end gap-6 reveal fade-in-up"
    >
      <div class="max-w-2xl">
        <h2 class="font-display-lg text-display-lg mb-4">
          Encuentra la propiedad de tus sueños
        </h2>
        <p class="text-secondary font-body-lg">
          Explora nuestras exclusivas propiedades en las ubicaciones más
          prestigiosas de Perú. Tenemos el espacio perfecto para tu visión.
        </p>
      </div>
      <div class="flex gap-4 mb-2">
        <button
          class="w-12 h-12 rounded-full border border-outline flex items-center justify-center hover:bg-primary hover:text-white transition-all duration-300 group"
          id="propPrevBtn"
          aria-label="Propiedad Anterior"
        >
          <span
            class="material-symbols-outlined group-active:-translate-x-1 transition-transform"
            >chevron_left</span
          >
        </button>
        <button
          class="w-12 h-12 rounded-full bg-primary text-white flex items-center justify-center hover:bg-opacity-90 transition-all duration-300 group"
          id="propNextBtn"
          aria-label="Propiedad Siguiente"
        >
          <span
            class="material-symbols-outlined group-active:translate-x-1 transition-transform"
            >chevron_right</span
          >
        </button>
      </div>
    </div>
  </div>

  <div
    class="relative px-margin-mobile md:px-margin-desktop overflow-hidden reveal fade-in delay-200"
  >
    <div
      class="flex gap-gutter pb-8 transition-transform duration-500 ease-in-out"
      id="propertiesTrack"
    >
      <!-- Property Card 1 -->
      <div
        class="min-w-[280px] w-[85vw] sm:w-[480px] md:w-[600px] md:min-w-[600px] group transition-all duration-300 relative-card"
      >
        <div
          class="relative aspect-[16/10] rounded-[24px] overflow-hidden mb-6 shadow-sm group-hover:shadow-md transition-all duration-300"
        >
          <Image
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            src={prop1}
            alt="Penthouse en Miraflores"
            loading="lazy"
            width={600}
            height={375}
            quality={80}
          />
          <div
            class="absolute top-6 left-6 bg-white/80 backdrop-blur-md px-4 py-1.5 rounded-full flex items-center gap-2 shadow-sm"
          >
            <span
              class="material-symbols-outlined text-sm text-primary font-bold"
              style="font-variation-settings: 'FILL' 1">verified</span
            >
            <span
              class="text-label-sm uppercase tracking-wider font-bold text-black"
              >Disponible</span
            >
          </div>
        </div>
        <div class="space-y-4">
          <div
            class="flex flex-col sm:flex-row justify-between items-start sm:items-baseline gap-2 sm:gap-4"
          >
            <h3
              class="font-display-lg text-headline-md text-[#0A1128] font-bold group-hover:text-primary transition-colors duration-300"
            >
              Penthouse Malecón de Miraflores
            </h3>
            <span
              class="font-display-lg text-headline-md text-primary font-bold shrink-0"
              >S/ 5,800,000</span
            >
          </div>
          <p class="text-secondary font-body-md leading-relaxed line-clamp-2">
            Espectacular penthouse con vista panorámica al mar, terraza privada,
            piscina climatizada y acabados de lujo.
          </p>
          <div class="flex flex-wrap gap-3 pt-2">
            <div
              class="flex items-center gap-2 bg-[#F3F3F4] px-4 py-2 rounded-xl text-secondary font-semibold text-sm"
            >
              <span class="material-symbols-outlined text-lg">square_foot</span>
              <span>320 m²</span>
            </div>
            <div
              class="flex items-center gap-2 bg-[#F3F3F4] px-4 py-2 rounded-xl text-secondary font-semibold text-sm"
            >
              <span class="material-symbols-outlined text-lg">bed</span>
              <span>4 Dorm.</span>
            </div>
            <div
              class="flex items-center gap-2 bg-[#F3F3F4] px-4 py-2 rounded-xl text-secondary font-semibold text-sm"
            >
              <span class="material-symbols-outlined text-lg">bathtub</span>
              <span>4.5 Baños</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Property Card 2 -->
      <div
        class="min-w-[280px] w-[85vw] sm:w-[480px] md:w-[600px] md:min-w-[600px] group transition-all duration-300 relative-card"
      >
        <div
          class="relative aspect-[16/10] rounded-[24px] overflow-hidden mb-6 shadow-sm group-hover:shadow-md transition-all duration-300"
        >
          <Image
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            src={prop2}
            alt="Villa de Playa en Asia"
            loading="lazy"
            width={600}
            height={375}
            quality={80}
          />
          <div
            class="absolute top-6 left-6 bg-white/80 backdrop-blur-md px-4 py-1.5 rounded-full flex items-center gap-2 shadow-sm"
          >
            <span
              class="material-symbols-outlined text-sm text-primary"
              style="font-variation-settings: 'FILL' 1">verified</span
            >
            <span
              class="text-label-sm uppercase tracking-wider font-bold text-black"
              >Disponible</span
            >
          </div>
        </div>
        <div class="space-y-4">
          <div
            class="flex flex-col sm:flex-row justify-between items-start sm:items-baseline gap-2 sm:gap-4"
          >
            <h3
              class="font-display-lg text-headline-md text-[#0A1128] font-bold group-hover:text-primary transition-colors duration-300"
            >
              Villa de Playa en Asia
            </h3>
            <span
              class="font-display-lg text-headline-md text-primary font-bold shrink-0"
              >S/ 4,200,000</span
            >
          </div>
          <p class="text-secondary font-body-md leading-relaxed line-clamp-2">
            Exclusiva casa frente al mar en la zona más segura de Asia (Km 97),
            con amplias terrazas y acabados de mármol.
          </p>
          <div class="flex flex-wrap gap-3 pt-2">
            <div
              class="flex items-center gap-2 bg-[#F3F3F4] px-4 py-2 rounded-xl text-secondary font-semibold text-sm"
            >
              <span class="material-symbols-outlined text-lg">square_foot</span>
              <span>450 m²</span>
            </div>
            <div
              class="flex items-center gap-2 bg-[#F3F3F4] px-4 py-2 rounded-xl text-secondary font-semibold text-sm"
            >
              <span class="material-symbols-outlined text-lg">bed</span>
              <span>5 Dorm.</span>
            </div>
            <div
              class="flex items-center gap-2 bg-[#F3F3F4] px-4 py-2 rounded-xl text-secondary font-semibold text-sm"
            >
              <span class="material-symbols-outlined text-lg">bathtub</span>
              <span>6 Baños</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Property Card 3 -->
      <div
        class="min-w-[280px] w-[85vw] sm:w-[480px] md:w-[600px] md:min-w-[600px] group transition-all duration-300 relative-card"
      >
        <div
          class="relative aspect-[16/10] rounded-[24px] overflow-hidden mb-6 shadow-sm group-hover:shadow-md transition-all duration-300"
        >
          <Image
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            src={prop3}
            alt="Residencia en La Molina"
            loading="lazy"
            width={600}
            height={375}
            quality={80}
          />
          <div
            class="absolute top-6 left-6 bg-white/80 backdrop-blur-md px-4 py-1.5 rounded-full flex items-center gap-2 shadow-sm"
          >
            <span
              class="material-symbols-outlined text-sm text-primary"
              style="font-variation-settings: 'FILL' 1">verified</span
            >
            <span
              class="text-label-sm uppercase tracking-wider font-bold text-black"
              >Disponible</span
            >
          </div>
        </div>
        <div class="space-y-4">
          <div
            class="flex flex-col sm:flex-row justify-between items-start sm:items-baseline gap-2 sm:gap-4"
          >
            <h3
              class="font-display-lg text-headline-md text-[#0A1128] font-bold group-hover:text-primary transition-colors duration-300"
            >
              Residencia en La Molina
            </h3>
            <span
              class="font-display-lg text-headline-md text-primary font-bold shrink-0"
              >S/ 3,900,000</span
            >
          </div>
          <p class="text-secondary font-body-md leading-relaxed line-clamp-2">
            Imponente residencia de diseño contemporáneo en Las Lagunas, rodeada
            de áreas verdes y total seguridad.
          </p>
          <div class="flex flex-wrap gap-3 pt-2">
            <div
              class="flex items-center gap-2 bg-[#F3F3F4] px-4 py-2 rounded-xl text-secondary font-semibold text-sm"
            >
              <span class="material-symbols-outlined text-lg">square_foot</span>
              <span>550 m²</span>
            </div>
            <div
              class="flex items-center gap-2 bg-[#F3F3F4] px-4 py-2 rounded-xl text-secondary font-semibold text-sm"
            >
              <span class="material-symbols-outlined text-lg">bed</span>
              <span>4 Dorm.</span>
            </div>
            <div
              class="flex items-center gap-2 bg-[#F3F3F4] px-4 py-2 rounded-xl text-secondary font-semibold text-sm"
            >
              <span class="material-symbols-outlined text-lg">bathtub</span>
              <span>5 Baños</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Property Card 4 -->
      <div
        class="min-w-[280px] w-[85vw] sm:w-[480px] md:w-[600px] md:min-w-[600px] group transition-all duration-300 relative-card"
      >
        <div
          class="relative aspect-[16/10] rounded-[24px] overflow-hidden mb-6 shadow-sm group-hover:shadow-md transition-all duration-300"
        >
          <Image
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            src={prop4}
            alt="Villa en Urubamba"
            loading="lazy"
            width={600}
            height={375}
            quality={80}
          />
          <div
            class="absolute top-6 left-6 bg-white/80 backdrop-blur-md px-4 py-1.5 rounded-full flex items-center gap-2 shadow-sm"
          >
            <span
              class="material-symbols-outlined text-sm text-primary"
              style="font-variation-settings: 'FILL' 1">verified</span
            >
            <span
              class="text-label-sm uppercase tracking-wider font-bold text-black"
              >Disponible</span
            >
          </div>
        </div>
        <div class="space-y-4">
          <div
            class="flex flex-col sm:flex-row justify-between items-start sm:items-baseline gap-2 sm:gap-4"
          >
            <h3
              class="font-display-lg text-headline-md text-[#0A1128] font-bold group-hover:text-primary transition-colors duration-300"
            >
              Villas de Lujo en Urubamba
            </h3>
            <span
              class="font-display-lg text-headline-md text-primary font-bold shrink-0"
              >S/ 2,800,000</span
            >
          </div>
          <p class="text-secondary font-body-md leading-relaxed line-clamp-2">
            Hermosa villa orgánica integrada con el paisaje andino del Valle
            Sagrado, perfecta para reconectar con la naturaleza.
          </p>
          <div class="flex flex-wrap gap-3 pt-2">
            <div
              class="flex items-center gap-2 bg-[#F3F3F4] px-4 py-2 rounded-xl text-secondary font-semibold text-sm"
            >
              <span class="material-symbols-outlined text-lg">square_foot</span>
              <span>600 m²</span>
            </div>
            <div
              class="flex items-center gap-2 bg-[#F3F3F4] px-4 py-2 rounded-xl text-secondary font-semibold text-sm"
            >
              <span class="material-symbols-outlined text-lg">bed</span>
              <span>3 Dorm.</span>
            </div>
            <div
              class="flex items-center gap-2 bg-[#F3F3F4] px-4 py-2 rounded-xl text-secondary font-semibold text-sm"
            >
              <span class="material-symbols-outlined text-lg">bathtub</span>
              <span>3.5 Baños</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Carousel Dots Indicators -->
    <div class="flex justify-center gap-3 mb-2 mt-4" id="propertiesDots">
      <button
        aria-label="Ir al slide 1"
        class="prop-dot w-3 h-3 rounded-full bg-outline/30 hover:bg-outline/50 transition-all duration-300 active"
        data-index="0"></button>
      <button
        aria-label="Ir al slide 2"
        class="prop-dot w-3 h-3 rounded-full bg-outline/30 hover:bg-outline/50 transition-all duration-300"
        data-index="1"></button>
      <button
        aria-label="Ir al slide 3"
        class="prop-dot w-3 h-3 rounded-full bg-outline/30 hover:bg-outline/50 transition-all duration-300"
        data-index="2"></button>
      <button
        aria-label="Ir al slide 4"
        class="prop-dot w-3 h-3 rounded-full bg-outline/30 hover:bg-outline/50 transition-all duration-300"
        data-index="3"></button>
    </div>
  </div>
</section>

<style>
  /* Extra transitions for property cards */
  .relative-card {
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
  }
  .prop-dot.active {
    background-color: #000000;
    transform: scale(1.2);
  }
</style>

<script>
  function setupPropertiesCarousel() {
    const track = document.getElementById("propertiesTrack") as HTMLElement;
    const prevBtn = document.getElementById("propPrevBtn");
    const nextBtn = document.getElementById("propNextBtn");
    const dots = document.querySelectorAll(".prop-dot");
    const cards = document.querySelectorAll("#propertiesTrack > div");

    if (!track || cards.length === 0) return;

    let currentIndex = 0;

    const updateCarousel = () => {
      const parent = track.parentElement;
      if (!parent) return;

      const containerWidth = parent.offsetWidth;
      const paddingLeft =
        parseFloat(window.getComputedStyle(parent).paddingLeft) || 0;
      const paddingRight =
        parseFloat(window.getComputedStyle(parent).paddingRight) || 0;
      const parentContentWidth = containerWidth - paddingLeft - paddingRight;

      const cardWidth = (cards[0] as HTMLElement).offsetWidth;
      const gap = parseFloat(window.getComputedStyle(track).gap) || 0;
      const moveAmount = cardWidth + gap;

      const totalTrackWidth = track.scrollWidth;

      const maxTranslate = totalTrackWidth - parentContentWidth;

      let translateAmount = currentIndex * moveAmount;

      if (translateAmount > maxTranslate && maxTranslate > 0) {
        translateAmount = maxTranslate;
      }
      if (translateAmount < 0) {
        translateAmount = 0;
      }

      track.style.transform = `translateX(-${translateAmount}px)`;

      cards.forEach((card, i) => {
        if (i === currentIndex) {
          card.classList.remove("opacity-40");
        } else {
          if (window.innerWidth >= 768) {
            card.classList.add("opacity-40");
          } else {
            card.classList.remove("opacity-40");
          }
        }
      });

      dots.forEach((dot, i) => {
        if (i === currentIndex) {
          dot.classList.add("active");
        } else {
          dot.classList.remove("active");
        }
      });
    };

    nextBtn?.addEventListener("click", () => {
      if (currentIndex < cards.length - 1) {
        currentIndex++;
        updateCarousel();
      } else {
        currentIndex = 0;
        updateCarousel();
      }
    });

    prevBtn?.addEventListener("click", () => {
      if (currentIndex > 0) {
        currentIndex--;
        updateCarousel();
      } else {
        currentIndex = cards.length - 1;
        updateCarousel();
      }
    });

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        currentIndex = index;
        updateCarousel();
      });
    });

    window.addEventListener("resize", updateCarousel);
    updateCarousel();
  }

  function deferredInit() {
    if (typeof requestIdleCallback !== "undefined") {
      requestIdleCallback(setupPropertiesCarousel);
    } else {
      setTimeout(setupPropertiesCarousel, 200);
    }
  }

  document.addEventListener("DOMContentLoaded", deferredInit);
  document.addEventListener("astro:page-load", deferredInit);
</script>
