---
import { Image } from "astro:assets";
import prop1 from "../assets/images/properties-1.webp";
import prop2 from "../assets/images/properties-2.webp";
import prop3 from "../assets/images/properties-3.webp";
import prop4 from "../assets/images/properties-4.webp";
---

<section class="py-stack-lg bg-white overflow-hidden" id="propiedades-destacadas">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-12">
    <div class="flex flex-col md:flex-row justify-between items-end gap-6 reveal fade-in-up">
      <div class="max-w-2xl">
        <h2 class="font-display-lg text-display-lg mb-4">Encuentra el hogar de tus sueños</h2>
        <p class="text-secondary font-body-lg">Explora nuestras exclusivas propiedades en las ubicaciones más prestigiosas de Perú. Tenemos el espacio perfecto para tu visión.</p>
      </div>
      <div class="flex gap-4 mb-2">
        <button class="w-12 h-12 rounded-full border border-outline flex items-center justify-center hover:bg-primary hover:text-white transition-all duration-300 group" id="propPrevBtn" aria-label="Propiedad Anterior">
          <span class="material-symbols-outlined group-active:-translate-x-1 transition-transform">chevron_left</span>
        </button>
        <button class="w-12 h-12 rounded-full bg-primary text-white flex items-center justify-center hover:bg-opacity-90 transition-all duration-300 group" id="propNextBtn" aria-label="Propiedad Siguiente">
          <span class="material-symbols-outlined group-active:translate-x-1 transition-transform">chevron_right</span>
        </button>
      </div>
    </div>
  </div>
  <div class="relative px-margin-mobile md:px-margin-desktop overflow-hidden reveal fade-in delay-200">
    <div class="flex gap-gutter pb-8 transition-transform duration-500 ease-in-out" id="propertiesTrack">
      <!-- Property Card 1 -->
      <div class="min-w-[300px] w-[85vw] md:w-[600px] md:min-w-[600px] group transition-all duration-300 relative-card">
        <div class="relative aspect-[16/10] rounded-xl overflow-hidden mb-6">
          <Image class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src={prop1} alt="Penthouse en Miraflores" loading="lazy" />
          <div class="absolute top-6 left-6 bg-white/80 backdrop-blur-md px-4 py-1 rounded-full flex items-center gap-2">
            <span class="material-symbols-outlined text-sm text-primary" style="font-variation-settings: 'FILL' 1">verified</span>
            <span class="text-label-sm uppercase tracking-wider font-bold">Disponible</span>
          </div>
        </div>
        <div class="flex justify-between items-start mb-4">
          <div>
            <h3 class="font-headline-md text-headline-md mb-2">Penthouse Malecón de Miraflores</h3>
            <p class="text-secondary font-body-md max-w-md">Espectacular penthouse con vista panorámica al mar, terraza privada, piscina templada y acabados de lujo.</p>
          </div>
          <div class="text-right">
            <p class="font-headline-md text-headline-md text-primary">S/ 5,800,000</p>
          </div>
        </div>
        <div class="flex flex-wrap justify-between items-center gap-4">
          <div class="flex gap-6 text-secondary font-label-sm font-semibold">
            <span class="flex items-center gap-2"><span class="material-symbols-outlined text-lg">square_foot</span> 320 m²</span>
            <span class="flex items-center gap-2"><span class="material-symbols-outlined text-lg">bed</span> 4 Dorm</span>
            <span class="flex items-center gap-2"><span class="material-symbols-outlined text-lg">bathtub</span> 4.5 Baños</span>
          </div>
          <button class="px-8 py-3 bg-primary text-white rounded-lg font-label-sm hover:bg-opacity-90 transition-all duration-300">DETALLES</button>
        </div>
      </div>

      <!-- Property Card 2 -->
      <div class="min-w-[300px] w-[85vw] md:w-[600px] md:min-w-[600px] group transition-all duration-300 relative-card">
        <div class="relative aspect-[16/10] rounded-xl overflow-hidden mb-6">
          <Image class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src={prop2} alt="Villa de Playa en Asia" loading="lazy" />
          <div class="absolute top-6 left-6 bg-white/80 backdrop-blur-md px-4 py-1 rounded-full flex items-center gap-2">
            <span class="material-symbols-outlined text-sm text-primary" style="font-variation-settings: 'FILL' 1">verified</span>
            <span class="text-label-sm uppercase tracking-wider font-bold">Disponible</span>
          </div>
        </div>
        <div class="flex justify-between items-start mb-4">
          <div>
            <h3 class="font-headline-md text-headline-md mb-2">Villa de Playa en Asia</h3>
            <p class="text-secondary font-body-md max-w-md">Exclusiva casa frente al mar en la zona más segura de Asia (Km 97), con amplias terrazas y acabados de mármol.</p>
          </div>
          <div class="text-right">
            <p class="font-headline-md text-headline-md text-primary">S/ 4,200,000</p>
          </div>
        </div>
        <div class="flex flex-wrap justify-between items-center gap-4">
          <div class="flex gap-6 text-secondary font-label-sm font-semibold">
            <span class="flex items-center gap-2"><span class="material-symbols-outlined text-lg">square_foot</span> 450 m²</span>
            <span class="flex items-center gap-2"><span class="material-symbols-outlined text-lg">bed</span> 5 Dorm</span>
            <span class="flex items-center gap-2"><span class="material-symbols-outlined text-lg">bathtub</span> 6 Baños</span>
          </div>
          <button class="px-8 py-3 bg-primary text-white rounded-lg font-label-sm hover:bg-opacity-90 transition-all duration-300">DETALLES</button>
        </div>
      </div>

      <!-- Property Card 3 -->
      <div class="min-w-[300px] w-[85vw] md:w-[600px] md:min-w-[600px] group transition-all duration-300 relative-card">
        <div class="relative aspect-[16/10] rounded-xl overflow-hidden mb-6">
          <Image class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src={prop3} alt="Residencia en La Molina" loading="lazy" />
          <div class="absolute top-6 left-6 bg-white/80 backdrop-blur-md px-4 py-1 rounded-full flex items-center gap-2">
            <span class="material-symbols-outlined text-sm text-primary" style="font-variation-settings: 'FILL' 1">verified</span>
            <span class="text-label-sm uppercase tracking-wider font-bold">Disponible</span>
          </div>
        </div>
        <div class="flex justify-between items-start mb-4">
          <div>
            <h3 class="font-headline-md text-headline-md mb-2">Moderna Residencia en La Molina</h3>
            <p class="text-secondary font-body-md max-w-md">Imponente residencia con diseño contemporáneo y techos altos en Las Lagunas, rodeada de áreas verdes y total seguridad.</p>
          </div>
          <div class="text-right">
            <p class="font-headline-md text-headline-md text-primary">S/ 3,900,000</p>
          </div>
        </div>
        <div class="flex flex-wrap justify-between items-center gap-4">
          <div class="flex gap-6 text-secondary font-label-sm font-semibold">
            <span class="flex items-center gap-2"><span class="material-symbols-outlined text-lg">square_foot</span> 550 m²</span>
            <span class="flex items-center gap-2"><span class="material-symbols-outlined text-lg">bed</span> 4 Dorm</span>
            <span class="flex items-center gap-2"><span class="material-symbols-outlined text-lg">bathtub</span> 5 Baños</span>
          </div>
          <button class="px-8 py-3 bg-primary text-white rounded-lg font-label-sm hover:bg-opacity-90 transition-all duration-300">DETALLES</button>
        </div>
      </div>

      <!-- Property Card 4 -->
      <div class="min-w-[300px] w-[85vw] md:w-[600px] md:min-w-[600px] group transition-all duration-300 relative-card">
        <div class="relative aspect-[16/10] rounded-xl overflow-hidden mb-6">
          <Image class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src={prop4} alt="Villa en Urubamba" loading="lazy" />
          <div class="absolute top-6 left-6 bg-white/80 backdrop-blur-md px-4 py-1 rounded-full flex items-center gap-2">
            <span class="material-symbols-outlined text-sm text-primary" style="font-variation-settings: 'FILL' 1">verified</span>
            <span class="text-label-sm uppercase tracking-wider font-bold">Disponible</span>
          </div>
        </div>
        <div class="flex justify-between items-start mb-4">
          <div>
            <h3 class="font-headline-md text-headline-md mb-2">Villas de Lujo en Urubamba</h3>
            <p class="text-secondary font-body-md max-w-md">Hermosa villa orgánica integrada con el paisaje andino del Valle Sagrado, perfecta para reconectar con la naturaleza.</p>
          </div>
          <div class="text-right">
            <p class="font-headline-md text-headline-md text-primary">S/ 2,800,000</p>
          </div>
        </div>
        <div class="flex flex-wrap justify-between items-center gap-4">
          <div class="flex gap-6 text-secondary font-label-sm font-semibold">
            <span class="flex items-center gap-2"><span class="material-symbols-outlined text-lg">square_foot</span> 600 m²</span>
            <span class="flex items-center gap-2"><span class="material-symbols-outlined text-lg">bed</span> 3 Dorm</span>
            <span class="flex items-center gap-2"><span class="material-symbols-outlined text-lg">bathtub</span> 3.5 Baños</span>
          </div>
          <button class="px-8 py-3 bg-primary text-white rounded-lg font-label-sm hover:bg-opacity-90 transition-all duration-300">DETALLES</button>
        </div>
      </div>
    </div>

    <!-- Carousel Dots Indicators -->
    <div class="flex justify-center gap-3 mt-4" id="propertiesDots">
      <button aria-label="Ir al slide 1" class="prop-dot w-3 h-3 rounded-full bg-primary transition-all duration-300 active" data-index="0"></button>
      <button aria-label="Ir al slide 2" class="prop-dot w-3 h-3 rounded-full bg-outline/30 hover:bg-outline/50 transition-all duration-300" data-index="1"></button>
      <button aria-label="Ir al slide 3" class="prop-dot w-3 h-3 rounded-full bg-outline/30 hover:bg-outline/50 transition-all duration-300" data-index="2"></button>
      <button aria-label="Ir al slide 4" class="prop-dot w-3 h-3 rounded-full bg-outline/30 hover:bg-outline/50 transition-all duration-300" data-index="3"></button>
    </div>
  </div>
</section>

<style>
  /* Extra transitions for property cards */
  .relative-card {
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  
  .prop-dot.active {
    background-color: #000000;
    transform: scale(1.2);
  }
</style>

<script>
  function setupPropertiesCarousel() {
    const track = document.getElementById("propertiesTrack") as HTMLElement;
    const prevBtn = document.getElementById("propPrevBtn");
    const nextBtn = document.getElementById("propNextBtn");
    const dots = document.querySelectorAll(".prop-dot");
    const cards = document.querySelectorAll("#propertiesTrack > div");

    if (!track || cards.length === 0) return;

    let currentIndex = 0;

    const updateCarousel = () => {
      const cardWidth = (cards[0] as HTMLElement).offsetWidth;
      const gap = parseFloat(window.getComputedStyle(track).gap) || 0;
      const moveAmount = cardWidth + gap;

      // On mobile, translate fully. On desktop, translate smoothly.
      track.style.transform = `translateX(-${currentIndex * moveAmount}px)`;

      // Update Card Opacity classes to match "active/inactive" style
      cards.forEach((card, i) => {
        if (i === currentIndex) {
          card.classList.remove("opacity-40");
        } else {
          // Keep it semi-transparent on desktop if we want that gallery feel
          if (window.innerWidth >= 768) {
            card.classList.add("opacity-40");
          } else {
            card.classList.remove("opacity-40");
          }
        }
      });

      // Update Dot Indicators Active Class
      dots.forEach((dot, i) => {
        if (i === currentIndex) {
          dot.classList.add("active");
        } else {
          dot.classList.remove("active");
        }
      });
    };

    // Next Button Click
    nextBtn?.addEventListener("click", () => {
      if (currentIndex < cards.length - 1) {
        currentIndex++;
        updateCarousel();
      } else {
        currentIndex = 0; // Loop back
        updateCarousel();
      }
    });

    // Prev Button Click
    prevBtn?.addEventListener("click", () => {
      if (currentIndex > 0) {
        currentIndex--;
        updateCarousel();
      } else {
        currentIndex = cards.length - 1; // Loop to end
        updateCarousel();
      }
    });

    // Dot Indicators Click
    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        currentIndex = index;
        updateCarousel();
      });
    });

    // Recalculate on window resize
    window.addEventListener("resize", updateCarousel);

    // Initial trigger
    updateCarousel();
  }

  document.addEventListener("DOMContentLoaded", setupPropertiesCarousel);
  document.addEventListener("astro:page-load", setupPropertiesCarousel);
</script>
