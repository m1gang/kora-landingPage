---
import { Image } from "astro:assets";
import imgVidaUrbana from "../assets/images/gallery-vida-urbana.webp";
import imgPlayas from "../assets/images/gallery-ecologicas.webp";
import imgLujoModerno from "../assets/images/gallery-lujo.webp";
import imgHogaresHerencia from "../assets/images/gallery-casa-campo.webp";
import imgRetirosCampo from "../assets/images/gallery-casa-invierno.webp";
---

<section class="py-stack-lg overflow-hidden" id="blog">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop text-center mb-16 reveal fade-in-up">
    <h2 class="font-display-lg text-display-lg">Explora por Estilo</h2>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-gutter px-margin-mobile md:px-margin-desktop h-auto md:h-[800px]">
    <!-- Vida Urbana -->
    <div class="col-span-1 md:row-span-2 h-[350px] md:h-full rounded-[40px] overflow-hidden relative group reveal fade-in delay-100">
      <Image
        class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
        src={imgVidaUrbana}
        alt="Vida Urbana - Lofts modernos y Penthouses en el malecón de Miraflores"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent flex flex-col justify-end p-8 md:p-10">
        <h4 class="text-white font-headline-md text-headline-md mb-2">Vida Urbana</h4>
        <p class="text-white/80 text-sm font-body-md opacity-0 group-hover:opacity-100 transition-opacity duration-300 max-w-xs">
          Lofts modernos y Penthouses en el malecón de Miraflores.
        </p>
      </div>
    </div>

    <!-- Propiedades de Playa -->
    <div class="col-span-1 md:col-span-2 h-[250px] md:h-full rounded-[40px] overflow-hidden relative group reveal fade-in delay-200">
      <Image
        class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
        src={imgPlayas}
        alt="Propiedades de Playa - Asia y Paracas"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent flex flex-col justify-end p-8 md:p-10">
        <h4 class="text-white font-headline-md text-headline-md mb-2">Propiedades de Playa</h4>
        <p class="text-white/80 text-sm font-body-md opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          Villas exclusivas en Asia (Km 97) y casas frente al mar en Paracas.
        </p>
      </div>
    </div>

    <!-- Lujo Moderno -->
    <div class="col-span-1 h-[250px] md:h-full rounded-[40px] overflow-hidden relative group reveal fade-in delay-300">
      <Image
        class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
        src={imgLujoModerno}
        alt="Lujo Moderno - La Molina"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent flex flex-col justify-end p-8 md:p-10">
        <h4 class="text-white font-headline-md text-headline-md mb-2">Lujo Moderno</h4>
        <p class="text-white/80 text-sm font-body-md opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          Residencias con arquitectura de vanguardia en La Molina.
        </p>
      </div>
    </div>

    <!-- Hogares de Herencia -->
    <div class="col-span-1 h-[250px] md:h-full rounded-[40px] overflow-hidden relative group reveal fade-in delay-200">
      <Image
        class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
        src={imgHogaresHerencia}
        alt="Hogares de Herencia - Cusco"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent flex flex-col justify-end p-8 md:p-10">
        <h4 class="text-white font-headline-md text-headline-md mb-2">Hogares de Herencia</h4>
        <p class="text-white/80 text-sm font-body-md opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          Casonas restauradas con valor histórico en el centro del Cusco.
        </p>
      </div>
    </div>

    <!-- Retiros de Campo -->
    <div class="col-span-1 md:col-span-2 h-[250px] md:h-full rounded-[40px] overflow-hidden relative group reveal fade-in delay-300">
      <Image
        class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
        src={imgRetirosCampo}
        alt="Retiros de Campo - Cieneguilla y Valle Sagrado"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent flex flex-col justify-end p-8 md:p-10">
        <h4 class="text-white font-headline-md text-headline-md mb-2">Retiros de Campo</h4>
        <p class="text-white/80 text-sm font-body-md opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          Casas de diseño orgánico en Cieneguilla y el Valle Sagrado (Urubamba).
        </p>
      </div>
    </div>
  </div>
</section>
