---
import { Image } from "astro:assets";
import services1 from "../assets/images/services-1.webp";
import services2 from "../assets/images/services-2.webp";
import services3 from "../assets/images/services-3.webp";
---

<section class="py-stack-lg bg-surface animate-on-scroll" id="servicios">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-6 reveal fade-in">
      <h2 class="font-display-lg text-display-lg">Servicios Expertos para<br/>Compradores, Vendedores e Inversores</h2>
      <div class="flex flex-wrap gap-2 justify-end max-w-md">
        <span class="px-6 py-2 bg-surface-container rounded-full border border-outline/10 font-label-sm">Comercial</span>
        <span class="px-6 py-2 bg-white text-black rounded-full border border-outline/10 font-label-sm shadow-sm">Residencial</span>
        <span class="px-6 py-2 bg-surface-container rounded-full border border-outline/10 font-label-sm">Casas</span>
        <span class="px-6 py-2 bg-surface-container rounded-full border border-outline/10 font-label-sm">Locales</span>
        <span class="px-6 py-2 bg-surface-container rounded-full border border-outline/10 font-label-sm">Departamentos</span>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 items-start">
      <!-- Comprar una Vivienda -->
      <div class="space-y-8 reveal fade-in-up delay-100 group hover:-translate-y-2 transition-transform duration-500">
        <div class="rounded-[32px] overflow-hidden aspect-[4/3] shadow-lg group-hover:shadow-xl transition-shadow duration-500">
          <Image class="w-full h-full object-cover" src={services1} alt="Búsqueda de propiedades premium" loading="lazy" width={600} height={450} quality={80} />
        </div>
        <div class="space-y-3">
          <h3 class="font-headline-md text-headline-md">Comprar una Vivienda</h3>
          <p class="text-secondary font-body-md leading-relaxed">Encuentra tu lugar ideal con una experiencia personalizada en San Isidro, Miraflores y Barranco.</p>
        </div>
      </div>

      <!-- Vender una Propiedad -->
      <div class="space-y-8 md:pt-20 reveal fade-in-up delay-200 group hover:-translate-y-2 transition-transform duration-500">
        <div class="space-y-3 mb-8">
          <h3 class="font-headline-md text-headline-md">Vender una Propiedad</h3>
          <p class="text-secondary font-body-md leading-relaxed">Utilizamos marketing de alta gama y herramientas tecnológicas para asegurar que tu propiedad destaque y se venda al mejor valor de mercado.</p>
        </div>
        <div class="rounded-[32px] overflow-hidden aspect-[4/3] shadow-lg group-hover:shadow-xl transition-shadow duration-500">
          <Image class="w-full h-full object-cover" src={services2} alt="Venta de casas exclusivas" loading="lazy" width={600} height={450} quality={80} />
        </div>
      </div>

      <!-- Renta Exclusiva -->
      <div class="space-y-8 reveal fade-in-up delay-300 group hover:-translate-y-2 transition-transform duration-500">
        <div class="rounded-[32px] overflow-hidden aspect-[4/3] shadow-lg group-hover:shadow-xl transition-shadow duration-500 relative">
          <Image class="w-full h-full object-cover" src={services3} alt="Alquileres de lujo gestionados" loading="lazy" width={600} height={450} quality={80} />
          <div class="absolute bottom-4 left-4 right-4 flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-black/40 backdrop-blur-md text-white rounded-full text-[10px] uppercase">Lujo</span>
            <span class="px-3 py-1 bg-black/40 backdrop-blur-md text-white rounded-full text-[10px] uppercase">Garantía</span>
            <span class="px-3 py-1 bg-black/40 backdrop-blur-md text-white rounded-full text-[10px] uppercase">Asesoría</span>
            <span class="px-3 py-1 bg-black/40 backdrop-blur-md text-white rounded-full text-[10px] uppercase">Contratos</span>
          </div>
        </div>
        <div class="space-y-3">
          <h3 class="font-headline-md text-headline-md">Renta Exclusiva</h3>
          <p class="text-secondary font-body-md leading-relaxed">Gestionamos alquileres de lujo con contratos garantizados y asesoría legal integral para tu tranquilidad.</p>
        </div>
      </div>
    </div>
  </div>
</section>